@model ISproject.Domain.Models.Language

@{
    ViewData["Title"] = "Language Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
                <div class="card-body p-0">
                    <div class="bg-secondary py-5 text-white">
                        <i class="bi bi-chat-left-dots-fill fs-1"></i>
                        <h2 class="fw-bold mt-2">@Model.Name</h2>
                        <span class="badge bg-white text-secondary rounded-pill px-3 py-2 fw-bold shadow-sm">
                            ISO-CODE: @Model.Code
                        </span>
                    </div>
                    <div class="p-4">
                        <p class="text-muted mb-4">This language is currently available for news source categorization and article localized filtering.</p>

                        <div class="d-flex justify-content-center gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm fw-bold text-dark">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>