@model ISproject.Domain.Models.Category

@{
    ViewData["Title"] = "Delete Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger border-2 shadow-lg rounded-4">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-3">
                        <i class="bi bi-exclamation-octagon-fill fs-1"></i>
                    </div>
                    <h3 class="fw-bold">Delete Category?</h3>
                    <p class="text-muted mb-4">Are you sure you want to remove the <strong class="text-dark">"@Model.Code"</strong> category? This cannot be undone.</p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold">Permanently Delete</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Cancel, Keep it</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>