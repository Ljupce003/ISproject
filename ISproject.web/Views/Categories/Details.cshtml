@model ISproject.Domain.Models.Category

@{
    ViewData["Title"] = "Category Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="bg-info p-4 text-white text-center">
                        <i class="bi bi-tag-fill fs-1"></i>
                        <h2 class="fw-bold mt-2">@Model.Code</h2>
                    </div>
                    <div class="p-4">
                        <label class="text-muted small text-uppercase fw-bold">Description</label>
                        <p class="fs-5 text-dark border-bottom pb-3">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm text-dark fw-bold">Edit Category</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>