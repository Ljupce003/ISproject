@model ISproject.Domain.Models.Category

@{
    ViewData["Title"] = "Create Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-success py-3 px-4 border-0">
                    <h4 class="mb-0 text-white fw-bold"><i class="bi bi-folder-plus me-2"></i>New Category</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-bold">Category Code</label>
                            <input asp-for="Code" class="form-control border-2 shadow-sm" placeholder="e.g. technology" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <input asp-for="Description" class="form-control border-2 shadow-sm" placeholder="Brief summary of this topic..." />
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4 rounded-pill fw-bold">Create</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>