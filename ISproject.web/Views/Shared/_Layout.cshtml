<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Live News App</title>
	<script type="importmap"></script>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/ISproject.web.styles.css" asp-append-version="true" />

	<style>
		:root {
			--primary-color: #007bff; /* links, buttons */
			--secondary-color: #6c757d; /* muted text */
			--success-color: #28a745; /* optional for selected rows */
			--hover-color: #e9ecef; /* row hover */
			--card-bg: #ffffff; /* news cards */
			--footer-bg: #f8f9fa; /* footer */
			--text-color: #343a40;
		}

		.navbar-brand {
			font-weight: bold;
			font-size: 1.5rem;
			color: var(--primary-color) !important;
		}

		.navbar-nav .nav-link {
			color: var(--text-color);
			font-weight: 500;
			transition: color 0.2s;
		}
		.navbar-nav .nav-link:hover {
			color: var(--primary-color);
			text-decoration: underline;
		}
		
		.navbar-nav .nav-link.active {
			color: var(--primary-color);
			font-weight: bold;
		}

		footer {
			background-color: var(--footer-bg);
			padding: 1rem 0;
			font-size: 0.9rem;
			text-align: center;
			color: var(--secondary-color);
		}

	</style>
</head>
<body>
	<header>
		<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
			<div class="container-fluid">
				<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Live News App</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
						aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
					<ul class="navbar-nav flex-grow-1">
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
						</li>
						@* <li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
						</li> *@
						<li class="nav-item">
							<a class="nav-link  text-success" asp-area="" asp-controller="Countries" asp-action="Index">Countries</a>
						</li>
						<li class="nav-item">
							<a class="nav-link  text-success" asp-area="" asp-controller="Categories" asp-action="Index">Categories</a>
						</li>
						<li class="nav-item">
							<a class="nav-link  text-success" asp-area="" asp-controller="Languages" asp-action="Index">Languages</a>
						</li>
						<li class="nav-item me-5">
							<a class="nav-link text-success" asp-area="" asp-controller="NewsSources" asp-action="Index"><b>News Sources</b></a>
						</li>

						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="NewsArticles" asp-action="Index"><b>News Articles</b></a>
						</li>
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="BookmarkedArticles" asp-action="Index"><b>Bookmarks</b></a>
						</li>
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="BookmarkFolders" asp-action="Index"><b>Bookmark Folders</b></a>
						</li>


					</ul>
					<partial name="_LoginPartial" />
				</div>
			</div>
		</nav>
	</header>
	<div class="container">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<footer class="border-top footer text-muted">
		<div class="container">
			&copy; @DateTime.Today.Year - Ljupce Angelovski @* <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> *@
		</div>
	</footer>
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
