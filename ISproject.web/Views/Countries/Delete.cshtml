@model ISproject.Domain.Models.Country

@{
    ViewData["Title"] = "Delete Country";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-3">
                        <i class="bi bi-trash3-fill fs-1"></i>
                    </div>
                    <h3 class="fw-bold">Delete Country?</h3>
                    <p class="text-muted mb-4">
                        Are you sure you want to delete <strong class="text-dark">"@Model.Name"</strong>? <br />
                        Articles using this country code may lose their regional metadata.
                    </p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow">
                                Delete Permanently
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill border">Keep Country</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>