@model ISproject.Domain.Models.Country

@{
    ViewData["Title"] = "Add Country";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-success py-3 px-4 border-0">
                    <h4 class="mb-0 text-white fw-bold"><i class="bi bi-globe-americas me-2"></i>Add New Country</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-secondary">Country Name</label>
                            <input asp-for="Name" class="form-control border-2 shadow-sm" placeholder="e.g. United States" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Code" class="form-label fw-bold text-secondary">ISO Code (2-letter)</label>
                            <input asp-for="Code" class="form-control border-2 shadow-sm uppercase" maxlength="2" placeholder="e.g. US" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4 rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-plus-lg"></i> Create
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>