@model ISproject.Domain.Models.ArticleInFolder

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>ArticleInFolder</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NewsArticle)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NewsArticle.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BookmarkFolder)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BookmarkFolder.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateAdded)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateAdded)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> 
        <a asp-action="Index" asp-controller="BookmarkFolders" class="btn btn-info">Back to List</a>
    </form>
</div>
