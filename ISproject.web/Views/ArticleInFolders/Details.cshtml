@model ISproject.Domain.Models.ArticleInFolder

@{
    ViewData["Title"] = "Categorization Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-center align-items-center gap-4 mb-4">
                        <div class="text-center">
                            <i class="bi bi-file-earmark-pdf fs-1 text-danger"></i>
                            <div class="small fw-bold mt-2">Article</div>
                        </div>
                        <i class="bi bi-arrow-right fs-2 text-muted"></i>
                        <div class="text-center">
                            <i class="bi bi-folder-fill fs-1 text-warning"></i>
                            <div class="small fw-bold mt-2">Folder</div>
                        </div>
                    </div>

                    <h5 class="text-muted text-uppercase small fw-bold mb-1">Article Title</h5>
                    <h3 class="fw-bold mb-4">@Model.NewsArticle?.Title</h3>

                    <div class="bg-light p-4 rounded-4 mb-4 d-inline-block w-100">
                        <div class="row text-start">
                            <div class="col-6">
                                <label class="small text-muted d-block">Located In Folder</label>
                                <span class="fw-bold text-dark"><i class="bi bi-folder me-1"></i> @Model.BookmarkFolder?.Name</span>
                            </div>
                            <div class="col-6 border-start">
                                <label class="small text-muted d-block">Organized On</label>
                                <span class="fw-bold text-dark"><i class="bi bi-calendar3 me-1"></i> @Model.DateAdded?.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-2">
                        <a asp-action="Index" asp-controller="BookmarkFolders" class="btn btn-link text-secondary text-decoration-none">Back to Folders</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm fw-bold">Edit Category</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>