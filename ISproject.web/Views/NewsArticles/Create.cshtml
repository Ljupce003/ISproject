@model ISproject.Domain.Models.NewsArticle

@{
    ViewData["Title"] = "Create Article";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">News Articles</a></li>
                    <li class="breadcrumb-item active" aria-current="page">New Article</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-success py-4 px-4 border-0">
                    <div class="d-flex align-items-center text-white">
                        <div class="bg-white rounded-circle p-2 me-3 shadow-sm">
                            <i class="bi bi-plus-circle-fill text-success fs-4"></i>
                        </div>
                        <h3 class="mb-0 fw-bold">Create New News Article</h3>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="Title" class="form-label fw-bold text-secondary">Article Title</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-type-h1"></i></span>
                                    <input asp-for="Title" class="form-control border-start-0 py-2" placeholder="Enter the main headline..." />
                                </div>
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Author" class="form-label fw-bold text-secondary">Author</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person"></i></span>
                                    <input asp-for="Author" class="form-control border-start-0 py-2" placeholder="Writer's name" />
                                </div>
                                <span asp-validation-for="Author" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Source" class="form-label fw-bold text-secondary">Source</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-broadcast"></i></span>
                                    <input asp-for="Source" class="form-control border-start-0 py-2" placeholder="e.g. Fox News, Al Jazeera..." />
                                </div>
                                <span asp-validation-for="Source" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-bold text-secondary">Content Description</label>
                                <textarea asp-for="Description" class="form-control shadow-sm" rows="4" placeholder="Summarize the news story here..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="CategoryId" class="form-label fw-bold text-secondary">Category</label>
                                <select asp-for="CategoryId" class="form-select shadow-sm" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Choose Category --</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="LanguageId" class="form-label fw-bold text-secondary">Language</label>
                                <select asp-for="LanguageId" class="form-select shadow-sm" asp-items="ViewBag.LanguageId">
                                    <option value="">-- Choose Language --</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="CountryId" class="form-label fw-bold text-secondary">Country</label>
                                <select asp-for="CountryId" class="form-select shadow-sm" asp-items="ViewBag.CountryId">
                                    <option value="">-- Choose Country --</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Url" class="form-label fw-bold text-secondary">Article Link (URL)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-link-45deg"></i></span>
                                    <input asp-for="Url" class="form-control border-start-0 py-2" placeholder="https://..." />
                                </div>
                                <span asp-validation-for="Url" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ImageUrl" class="form-label fw-bold text-secondary">Image URL</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-image"></i></span>
                                    <input asp-for="ImageUrl" class="form-control border-start-0 py-2" placeholder="https://image-link.com/..." />
                                </div>
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PublishedAt" class="form-label fw-bold text-secondary">Publishing Date/Time</label>
                                <input asp-for="PublishedAt" class="form-control shadow-sm py-2" />
                                <span asp-validation-for="PublishedAt" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-4 pt-4 border-top">
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-success px-5 rounded-pill fw-bold shadow-sm">
                                        <i class="bi bi-plus-lg me-1"></i> Create Article
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary px-5 rounded-pill shadow-sm">
                                        Cancel
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}