@if (User.Identity?.IsAuthenticated ?? false)
{
	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const rows = document.querySelectorAll("tbody tr");
			const bookmarkBtn = document.querySelector("#bookmarkBtn");

			rows.forEach(row => {
				row.addEventListener("click", (e) => {
					const checkboxBtn = row.querySelector('input[type="checkbox"]');

					if (e.target.type !== "checkbox") {

						checkboxBtn.checked = !checkboxBtn.checked;
					}

					if (checkboxBtn.checked) {
						row.classList.add("selected-row");
					} else {
						row.classList.remove("selected-row");
					}

					const checkedCount = document.querySelectorAll('tbody input[type="checkbox"]:checked').length;
					bookmarkBtn.disabled = checkedCount === 0;
				});
			});
		});
	</script>
}
