@model IEnumerable<ISproject.Domain.Models.NewsArticle>

@{
    ViewData["Title"] = "Latest News";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Card Foundations */
    .news-card {
        transition: all 0.25s ease-in-out;
        cursor: pointer;
        border: 1px solid #e0e0e0;
        border-radius: 16px;
        height: 100%;
        position: relative;
        background: white;
    }

        .news-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
            border-color: #ced4da;
        }

    /* Selection Indicator (Top Right) */
    .selection-indicator {
        position: absolute;
        top: -10px;
        right: -10px;
        z-index: 10;
        display: none;
    }

    .selected-card {
        border: 2px solid #e83e8c !important;
        background-color: #fff0f5 !important; /* Soft pink tint */
    }

        .selected-card .selection-indicator {
            display: block;
        }

    /* Floating Action Bar */
    #floating-action-bar {
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1050;
        background: #ffffff;
        padding: 12px 25px;
        border-radius: 50px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        display: none; /* Controlled by JS */
        align-items: center;
        gap: 20px;
        border: 1px solid #e83e8c;
    }

    /* Action Buttons (Edit, Details, Delete) */
    .btn-action {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: transform 0.2s;
        border: none;
        color: white !important;
    }

        .btn-action:hover {
            transform: scale(1.1);
            filter: brightness(90%);
        }

    /* Description Truncation */
    .description-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 4.5rem;
        color: #6c757d;
    }

    .source-badge {
        background-color: #f8f9fa;
        color: #0d6efd;
        border: 1px solid #dee2e6;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
    }
</style>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold text-primary mb-0">📰 News Articles</h1>
            <p class="text-muted">Stay informed with the latest global headlines</p>
        </div>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="d-flex gap-2">
                <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-lg"></i> Create New
                </a>
                <button class="btn btn-outline-primary rounded-pill px-4 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#sourceForm">
                    <i class="bi bi-filter-right"></i> Fetch Articles
                </button>
            </div>
        }
    </div>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="collapse mb-5" id="sourceForm">
            <div class="card border-0 shadow-sm rounded-4 bg-light">
                <div class="card-body p-4">
                    <form method="get" asp-controller="Api" asp-action="GetNewsArticles" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Category</label>
                            <select name="category" class="form-select border-0 shadow-sm" asp-items="ViewBag.CategoryId"><option value="">All Categories</option></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Country</label>
                            <select name="country" class="form-select border-0 shadow-sm" asp-items="ViewBag.CountryId"><option value="">All Countries</option></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Language</label>
                            <select name="language" class="form-select border-0 shadow-sm" asp-items="ViewBag.LanguageId"><option value="">All Languages</option></select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Sort Order</label>
                            <select name="sort" class="form-select border-0 shadow-sm">
                                <option value="published_desc">Newest First</option>
                                <option value="popularity">Popularity</option>
                            </select>
                        </div>
                        <div class="col-12 text-end mt-3">
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow">Apply & Fetch</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <form id="bookmarkForm" method="post" asp-action="BookMarkArticles">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card news-card shadow-sm" data-article-id="@item.Id">

                        <div class="selection-indicator">
                            <span class="badge rounded-circle p-2 shadow" style="background-color: #e83e8c;">
                                <i class="bi bi-check-lg fs-5 text-white"></i>
                            </span>
                            <input class="d-none article-checkbox" type="checkbox" value="@item.Id" name="articleId" />
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="source-badge">@(item.Source ?? "News")</span>
                                <small class="text-muted"><i class="bi bi-clock"></i> @item.PublishedAt?.ToString("MMM dd, yyyy")</small>
                            </div>

                            <h5 class="card-title fw-bold text-dark mb-2">@(item.Title ?? "Untitled Article")</h5>
                            <p class="small text-muted mb-3">By @(item.Author ?? "Staff Writer")</p>

                            <p class="card-text description-clamp">
                                @(item.Description ?? "No description available for this article.")
                            </p>

                            <div class="d-flex flex-wrap gap-1 mt-2 mb-4">
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@item.Category?.Code</span>
                                <span class="badge bg-success-subtle text-success border border-success-subtle">@item.Country?.Name</span>
                            </div>

                            <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                @if (item.Url != null)
                                {
                                    <a href="@item.Url" target="_blank" class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-bold">Read More</a>
                                }

                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <div class="d-flex gap-1">
                                        <a class="btn btn-warning btn-action shadow-sm" asp-action="Edit" asp-route-id="@item.Id" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a class="btn btn-info btn-action shadow-sm" asp-action="Details" asp-route-id="@item.Id" title="Details">
                                            <i class="bi bi-info-circle-fill"></i>
                                        </a>
                                        <a class="btn btn-danger btn-action shadow-sm" asp-action="Delete" asp-route-id="@item.Id" title="Delete">
                                            <i class="bi bi-trash3-fill"></i>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div id="floating-action-bar">
            <div class="d-flex align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width:35px; height:35px; background:#e83e8c;">
                    <i class="bi bi-bookmarks-fill text-white"></i>
                </div>
                <span id="selected-count" class="fw-bold text-dark fs-5">0 Selected</span>
            </div>

            <div class="vr mx-3 my-1 text-muted" style="width: 2px;"></div>

            <button type="submit" class="btn btn-lg text-white px-4 rounded-pill fw-bold shadow-sm" style="background-color:#e83e8c;">
                Bookmark Selection
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const cards = document.querySelectorAll(".news-card");
            const floatingBar = document.querySelector("#floating-action-bar");
            const countLabel = document.querySelector("#selected-count");

            cards.forEach(card => {
                card.addEventListener("click", (e) => {
                    // Stop selection logic if a button or link is clicked
                    if (e.target.closest('.btn') || e.target.closest('a')) return;

                    const checkbox = card.querySelector('.article-checkbox');
                    checkbox.checked = !checkbox.checked;

                    // Visual Feedback
                    if (checkbox.checked) {
                        card.classList.add("selected-card");
                    } else {
                        card.classList.remove("selected-card");
                    }

                    updateFloatingBar();
                });
            });

            function updateFloatingBar() {
                const checkedCount = document.querySelectorAll('.article-checkbox:checked').length;
                countLabel.innerText = `${checkedCount} Selected`;

                if (checkedCount > 0) {
                    floatingBar.style.display = 'flex';
                } else {
                    floatingBar.style.display = 'none';
                }
            }
        });
    </script>
}