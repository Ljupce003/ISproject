@model IEnumerable<ISproject.Domain.Models.NewsArticle>

@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
	.big-checkbox {
		transform: scale(1.25); /* increase size */
		margin-right: 8px; /* fix spacing */
	}


	tbody tr.selected-row {
		--bs-table-bg: #fff0f5 !important; /* lavender pink */
		transition: background-color 0.2s ease-in-out;
	}


</style>

<div class="d-flex align-items-center justify-content-between mb-4">
	<h1 class="fw-bold text-primary">📰 News Articles</h1>
	@* <span class="badge bg-secondary fs-6">Total: @Model.Count()</span> *@
</div>



@if (User.Identity?.IsAuthenticated ?? false)
{
	<div class="card shadow-sm mb-4">
		<div class="card-body d-flex flex-wrap gap-2 align-items-center">
			<a asp-action="Create" class="btn btn-success">➕ Create New</a>
			<button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#sourceForm">
				🔄 Fetch Articles
			</button>
			
		</div>
	</div>
}



@if (User.Identity?.IsAuthenticated ?? false)
{
	<div class="collapse mt-3" id="sourceForm">
		<div class="card card-body shadow-sm">
			<form method="get" asp-controller="Api" asp-action="GetNewsArticles" class="row g-3">
				<div class="col-md-3">
					<label for="cat" class="form-label">Category</label>
					<select id="cat" name="category" class="form-select" asp-items="ViewBag.CategoryId">
						<option value=""></option>
					</select>
				</div>
				<div class="col-md-3">
					<label for="country" class="form-label">Country</label>
					<select id="country" name="country" class="form-select" asp-items="ViewBag.CountryId">
						<option value=""></option>
					</select>
				</div>
				<div class="col-md-3">
					<label for="lang" class="form-label">Language</label>
					<select id="lang" name="language" class="form-select" asp-items="ViewBag.LanguageId">
						<option value=""></option>
					</select>
				</div>
				<div class="col-md-3">
					<label for="sort" class="form-label">Sort</label>
					<select id="sort" name="sort" class="form-select">
						<option value="published_desc" selected>Published Descending</option>
						<option value="published_asc">Published Ascending</option>
						<option value="popularity">Popularity</option>
					</select>
				</div>
				<div class="col-12 text-end">
					<button type="submit" class="btn btn-outline-success mt-2 px-5">Fetch</button>
				</div>
			</form>
		</div>
	</div>
}



<form method="post" asp-action="BookMarkArticles" class="mt-5">
	<div class="d-flex gap-2 align-items-center mb-2">
		@if (User.Identity?.IsAuthenticated ?? false)
		{
			<input type="submit" value="Bookmark Articles" class="btn text-white" style="background-color:#e83e8c;" disabled id="bookmarkBtn" />
		}
		<h3 class="ms-auto mb-0"><span class="badge bg-secondary fs-6">Total: @Model.Count()</span></h3>
	</div>
	

	<div class="table-responsive">
		<table class="table table-striped table-hover align-middle mt-3">
			<thead class="table-light">
				<tr>
					@if (User.Identity?.IsAuthenticated ?? false)
					{
						<th>Bookmark</th>
					}
					<th>Title</th>
					<th>Author</th>
					<th>Description</th>
					<th>Url</th>
					<th>Source</th>
					<th>Category</th>
					<th>Language</th>
					<th>Country</th>
					<th>Published At</th>
					@if (User.Identity?.IsAuthenticated ?? false)
					{
						<th>Actions</th>
					}
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						@if (User.Identity?.IsAuthenticated ?? false)
						{
							<td>
								<input class="form-check-input big-checkbox" type="checkbox" value="@item.Id" name="articleId" />
							</td>
						}
						<td class="fw-bold text-truncate" style="max-width:200px;">@(item.Title ?? "")</td>
						<td>@(item.Author ?? "")</td>
						<td class="text-muted text-truncate" style="max-width:250px;">
							@(item.Description != null ? item.Description.Substring(0, Math.Min(item.Description.Length, 50)) + "..." : "")
						</td>
						<td>
							@if (item.Url != null)
							{
								<a href="@item.Url" target="_blank" class="btn btn-sm btn-outline-secondary">🔗 Link</a>
							}
						</td>
						<td>@(item.Source ?? "")</td>
						<td><span class="badge bg-primary">@item.Category?.Code</span></td>
						<td><span class="badge bg-info text-dark">@item.Language?.Name</span></td>
						<td><span class="badge bg-success">@item.Country?.Name</span></td>
						<td>@(item.PublishedAt?.ToString("yyyy-MM-dd HH:mm"))</td>
						@if (User.Identity?.IsAuthenticated ?? false)
						{
							<td>
								<div class="btn-group btn-group-sm" role="group">
									<a class="btn btn-warning" asp-action="Edit" asp-route-id="@item.Id">✏️</a>
									<a class="btn btn-info" asp-action="Details" asp-route-id="@item.Id">ℹ️</a>
									<a class="btn btn-danger" asp-action="Delete" asp-route-id="@item.Id">🗑️</a>
								</div>
							</td>
						}
					</tr>
				}
			</tbody>
		</table>
	</div>

		
</form>



