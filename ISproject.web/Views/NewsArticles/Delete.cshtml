@model ISproject.Domain.Models.NewsArticle

@{
    ViewData["Title"] = "Delete Article";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger py-4 text-center border-0">
                    <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2 shadow-sm" style="width: 60px; height: 60px;">
                        <i class="bi bi-trash3-fill text-danger fs-3"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-0">Confirm Deletion</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <p class="text-muted fs-5">Are you sure you want to permanently remove this article? This action cannot be undone.</p>
                    </div>

                    <div class="bg-light rounded-4 p-4 mb-4 border-start border-danger border-4">
                        <label class="small text-uppercase fw-bold text-danger mb-1">Article to be deleted:</label>
                        <h5 class="fw-bold text-dark mb-2">@Model.Title</h5>

                        <div class="d-flex flex-wrap gap-3 mt-3">
                            <div class="small text-secondary">
                                <i class="bi bi-person me-1"></i> @(Model.Author ?? "Unknown")
                            </div>
                            <div class="small text-secondary">
                                <i class="bi bi-broadcast me-1"></i> @Model.Source
                            </div>
                            <div class="small text-secondary">
                                <i class="bi bi-calendar-event me-1"></i> @Model.PublishedAt?.ToString("yyyy-MM-dd")
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <div class="p-2 border rounded-3 bg-white small">
                                <span class="text-muted d-block">Category</span>
                                <span class="fw-bold">@Model.Category?.Description</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 border rounded-3 bg-white small">
                                <span class="text-muted d-block">Country</span>
                                <span class="fw-bold">@Model.Country?.Name</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-trash3 me-2"></i> Permanently Delete
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill fw-bold">
                                No, Keep it
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">ID: @Model.Id</p>
            </div>
        </div>
    </div>
</div>