	<div class="d-flex gap-2 align-items-center mb-2">
		<h3 class="ms-auto mb-0"><span class="badge bg-secondary fs-6">Total: @Model.Count()</span></h3>
	</div>

	<div class="table-responsive mt-1">
		<table class="table table-striped table-hover align-middle mb-0">
			<thead>
				<tr>
					<th>Add to Folder</th>
					<th>@Html.DisplayNameFor(model => model.Article!.Title)</th>
					<th>@Html.DisplayNameFor(model => model.Article!.Description)</th>
					<th>@Html.DisplayNameFor(model => model.Article!.Author)</th>
					<th>@Html.DisplayNameFor(model => model.Article!.Url)</th>
					<th>@Html.DisplayNameFor(model => model.AddedAt)</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td>
							<div class="form-check">
								<input class="form-check-input big-checkbox" type="checkbox" value="@item.Id" name="bookmarkId">
							</div>
						</td>
						<td class="fw-semibold text-truncate" style="max-width: 220px;">
							@Html.DisplayFor(modelItem => item.Article!.Title)
						</td>
						<td class="text-truncate" style="max-width: 300px;">
							@(item.Article!.Description != null
													? item.Article.Description.Substring(0, Math.Min(item.Article.Description.Length, 50)) + "..."
													: "")
					</td>
					<td>@Html.DisplayFor(modelItem => item.Article.Author)</td>
					<td>
						<a href="@item.Article.Url" target="_blank" class="btn btn-sm btn-outline-secondary">🔗 Link</a>
					</td>
					<td>@item.AddedAt?.ToString("yyyy-MM-dd HH:mm")</td>
					<td>
						<div class="d-flex flex-column gap-1">
							<a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
							<a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id">Details</a>
							<a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
						</div>
					</td>
				</tr>
								}
			</tbody>
		</table>
	</div>
</form>




<script>
	document.addEventListener("DOMContentLoaded", () => {
		const rows = document.querySelectorAll("tbody tr");
		const folderBtn = document.querySelector("#folderBtn");
		const sourceForm = document.querySelector("#sourceForm");
		const folderSelect = document.querySelector("#folder");
		const folderNameGroup = document.querySelector("#folderNameGroup");

		const bsCollapse = new bootstrap.Collapse(sourceForm, { toggle: false });

		rows.forEach(row => {
			row.addEventListener("click", (e) => {
				const checkboxBtn = row.querySelector('input[type="checkbox"]');

				if(e.target.tagName.toLowerCase() === "a") return;

				if (e.target.type !== "checkbox") {

					checkboxBtn.checked = !checkboxBtn.checked;
				}

				if (checkboxBtn.checked) {
					row.classList.add("selected-row");
				} else {
					row.classList.remove("selected-row");
				}

				const checkedCount = document.querySelectorAll('tbody input[type="checkbox"]:checked').length;
				folderBtn.disabled = checkedCount === 0;

				if (checkedCount === 0) {
					bsCollapse.hide();
				}
			});
		});


		if (folderSelect.value === "NewFolder") {
			// folderNameGroup.style.display = "block";
			folderNameGroup.classList.add("show");
		} else {
			// folderNameGroup.style.display = "none";
			folderNameGroup.classList.remove("show");
		}

		// Listen for changes
		folderSelect.addEventListener("change", () => {
			if (folderSelect.value === "NewFolder") {
				// folderNameGroup.style.display = "block";
				folderNameGroup.classList.add("show");
			} else {
				// folderNameGroup.style.display = "none";
				folderNameGroup.classList.remove("show");
			}
		});



	});
</script>
