	tbody tr.selected-row {
		--bs-table-bg: #e0ecff !important; /* softer light royal blue */
		transition: background-color 0.2s ease;
	}

	.fade-toggle {
		opacity: 0;
		max-height: 0;
		overflow: hidden;
		transition: all 0.3s ease-in-out;
	}

	.fade-toggle.show {
		opacity: 1;
		max-height: 100px; /* adjust depending on div height */
	}

	/* Prevent wide text from breaking layout */
	.table td.text-truncate,
	.table th.text-truncate {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
</style>

