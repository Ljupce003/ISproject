@model IEnumerable<ISproject.Domain.Models.BookmarkedArticle>

@{
    ViewData["Title"] = "My Bookmarks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Selection Styling */
    .selected-row {
        background-color: #f0f7ff !important;
        border-left: 4px solid #0d6efd !important;
    }

    /* Checkbox scale */
    .big-checkbox {
        width: 1.2rem;
        height: 1.2rem;
        cursor: pointer;
    }

    /* Animation for the Folder Input */
    #folderNameGroup {
        transition: all 0.3s ease;
        display: none;
    }

        #folderNameGroup.show {
            display: block;
        }

    /* Utility */
    .text-truncate-custom {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold text-dark mb-0">🔖 Bookmarked Articles</h1>
            <p class="text-muted">Manage your saved reads and organize them into folders.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary rounded-pill px-3 py-2">@Model.Count() Total Bookmarks</span>
        </div>
    </div>

    <form method="post" asp-action="AddArticlesToFolder">

        <div class="card shadow-sm border-0 rounded-4 mb-4 sticky-top" style="top: 20px; z-index: 1020;">
            <div class="card-body d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div class="d-flex gap-2">
                    <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                        <i class="bi bi-plus-lg me-1"></i> New Bookmark
                    </a>
                    <button class="btn btn-primary rounded-pill px-4 shadow-sm" type="button"
                            data-bs-toggle="collapse" data-bs-target="#folderCollapse"
                            disabled id="folderBtn">
                        <i class="bi bi-folder-plus me-1"></i> Add to Folder
                    </button>
                </div>

                <div class="collapse flex-grow-1 mt-md-0 mt-3" id="folderCollapse">
                    <div class="bg-light p-3 rounded-4 d-flex flex-wrap align-items-end gap-3 border">
                        <div class="flex-grow-1">
                            <label class="form-label small fw-bold text-uppercase text-muted">Select Target Folder</label>
                            <select id="folder" name="folder" class="form-select shadow-sm" asp-items="ViewBag.Folders">
                                <option value="NewFolder">+ Create New Folder</option>
                            </select>
                        </div>
                        <div id="folderNameGroup" class="flex-grow-1">
                            <label class="form-label small fw-bold text-uppercase text-muted">New Folder Name</label>
                            <input type="text" id="folderName" name="folderName" class="form-control shadow-sm" placeholder="Work, Research, etc." />
                        </div>
                        <button type="submit" class="btn btn-dark px-4 rounded-pill">Confirm</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4" style="width: 50px;">
                                <i class="bi bi-check2-all"></i>
                            </th>
                            <th>Article Details</th>
                            <th>Author</th>
                            <th>Date Saved</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="cursor: pointer;" class="bookmark-row">
                                <td class="ps-4">
                                    <input class="form-check-input big-checkbox" type="checkbox" value="@item.Id" name="bookmarkId">
                                </td>
                                <td>
                                    <div class="fw-bold text-dark mb-0 text-truncate" style="max-width: 300px;">@item.Article!.Title</div>
                                    <small class="text-muted text-truncate-custom" style="max-width: 400px;">
                                        @item.Article.Description
                                    </small>
                                    <div class="mt-1">
                                        <a href="@item.Article.Url" target="_blank" class="badge bg-info-subtle text-info text-decoration-none border border-info-subtle">
                                            <i class="bi bi-link-45deg"></i> Source Link
                                        </a>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-secondary small fw-semibold"><i class="bi bi-person me-1"></i>@item.Article.Author</span>
                                </td>
                                <td>
                                    <div class="small text-muted">@item.AddedAt?.ToString("MMM dd, yyyy")</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@item.AddedAt?.ToString("HH:mm")</div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a class="btn btn-white btn-sm border-end" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="bi bi-pencil text-warning"></i></a>
                                        <a class="btn btn-white btn-sm border-end" asp-action="Details" asp-route-id="@item.Id" title="Details"><i class="bi bi-eye text-info"></i></a>
                                        <a class="btn btn-white btn-sm" asp-action="Delete" asp-route-id="@item.Id" title="Remove"><i class="bi bi-trash text-danger"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const rows = document.querySelectorAll(".bookmark-row");
            const folderBtn = document.querySelector("#folderBtn");
            const folderCollapse = document.getElementById('folderCollapse');
            const bsCollapse = new bootstrap.Collapse(folderCollapse, { toggle: false });
            const folderSelect = document.querySelector("#folder");
            const folderNameGroup = document.querySelector("#folderNameGroup");

            rows.forEach(row => {
                row.addEventListener("click", (e) => {
                    // Don't trigger if the actual link or action buttons are clicked
                    if (e.target.closest('a') || e.target.closest('.btn-group')) return;

                    const checkbox = row.querySelector('input[type="checkbox"]');
                    if (e.target.type !== "checkbox") {
                        checkbox.checked = !checkbox.checked;
                    }

                    row.classList.toggle("selected-row", checkbox.checked);

                    const checkedCount = document.querySelectorAll('tbody input[type="checkbox"]:checked').length;
                    folderBtn.disabled = checkedCount === 0;

                    if (checkedCount === 0) {
                        bsCollapse.hide();
                    }
                });
            });

            // Toggle new folder name field
            folderSelect.addEventListener("change", () => {
                if (folderSelect.value === "NewFolder") {
                    folderNameGroup.classList.add("show");
                } else {
                    folderNameGroup.classList.remove("show");
                }
            });
        });
    </script>
}