					<label for="folder" class="control-label">Folder</label>
					<select id="folder" name="folder" class="form-control" asp-items="ViewBag.Folders">
						<option value="NewFolder">New Folder</option>
					</select>
				</div>
				<div class="form-group fade-toggle" id="folderNameGroup">
					<label for="folderName" class="control-label">Folder Name</label>
					<input type="text" id="folderName" name="folderName" class="form-control" />
				</div>
				<button type="submit" class="btn btn-outline-success mt-2">Add To Folder</button>
			</div>
		</div>
	</div>

