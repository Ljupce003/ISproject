<div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
    <div class="container-fluid py-5 text-center">
        <h1 class="display-4 fw-bold">Live News App</h1>
        <p class="lead">Stay updated with the latest headlines, categories, and breaking news around the world.</p>
        <a class="btn btn-primary btn-lg" asp-controller="NewsArticles" asp-action="Index">Explore News</a>
    </div>
</div>


<div class="container text-center mb-5">
    <h2 class="mb-4">Browse</h2>
    <div>
        <a asp-controller="Categories" asp-action="Index" class="badge bg-primary text-dark m-1 p-3">Categories</a>
        <a asp-controller="Countries" asp-action="Index" class="badge bg-success text-dark m-1 p-3">Countries</a>
        <a asp-controller="Languages" asp-action="Index" class="badge bg-warning text-dark m-1 p-3">Languages</a>
        <a asp-controller="NewsSources" asp-action="Index" class="badge bg-info text-dark m-1 p-3">News Sources</a>
    </div>
</div>

<div class="text-center py-4 bg-light rounded shadow-sm">
    <h3>Save the news you love</h3>
    <p>Bookmark your favorite articles and organize them into folders.</p>
    <a class="btn btn-outline-primary" asp-controller="BookmarkedArticles" asp-action="Index">Go to Bookmarks</a>
</div>