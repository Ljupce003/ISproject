<div class="py-5 mb-4 bg-primary text-white rounded-4 shadow-lg mb-5">
    <div class="container py-5 text-center">
        <h1 class="display-3 fw-bold">Your Daily Feed, Redefined.</h1>
        <p class="fs-4">Curate, bookmark, and organize news from around the world.</p>
        <a class="btn btn-light btn-lg px-5 mt-3 fw-bold text-primary shadow" asp-controller="NewsArticles" asp-action="Index">Start Exploring</a>
    </div>
</div>

<div class="container mb-3">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 hover-lift">
                <i class="bi bi-newspaper fs-1 text-primary mb-3"></i>
                <h4 class="fw-bold">Latest News</h4>
                <p class="text-muted">Real-time articles from top global sources like CNN, BBC, and more.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 hover-lift">
                <i class="bi bi-bookmark-heart fs-1 text-danger mb-3"></i>
                <h4 class="fw-bold">Smart Bookmarks</h4>
                <p class="text-muted">Save articles you love and read them whenever you're ready.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 hover-lift">
                <i class="bi bi-folder-plus fs-1 text-warning mb-3"></i>
                <h4 class="fw-bold">Exportable Folders</h4>
                <p class="text-muted">Organize your research into folders and export them to Excel in one click.</p>
            </div>
        </div>
    </div>
</div>
<div class="h-25" style="color:transparent;">
    .
</div>