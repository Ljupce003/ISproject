@model ISproject.Domain.Models.BookmarkFolder

@{
    ViewData["Title"] = "Folder Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-3 px-4 border-0">
                    <h4 class="mb-0 text-white fw-bold">
                        <i class="bi bi-folder-plus me-2"></i>@(ViewData["Title"].ToString() == "Create" ? "New Folder" : "Rename Folder")
                    </h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="@ViewContext.RouteData.Values["action"]">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                        @if (ViewContext.RouteData.Values["action"]?.ToString() == "Edit")
                        {
                            <input type="hidden" asp-for="Id" />
                        }

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-secondary">Folder Name</label>
                            <input asp-for="Name" class="form-control form-control-lg border-2" placeholder="e.g., Tech Research 2024" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="UserId" class="form-label fw-bold text-secondary small text-uppercase">Owner ID (System)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-lock"></i></span>
                                <input asp-for="UserId" class="form-control bg-light border-start-0" value="@ViewBag.UserId" readonly />
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary px-4 rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-save me-1"></i> Save Folder
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}