@model ISproject.Domain.Models.BookmarkFolder

@{
    ViewData["Title"] = "Delete Folder";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-4">
                        <i class="bi bi-exclamation-octagon-fill" style="font-size: 4rem;"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Delete this folder?</h3>
                    <p class="text-muted mb-4">
                        You are about to delete <strong class="text-dark">"@Model.Name"</strong>.
                        This will un-group all articles inside this folder.
                    </p>

                    <form asp-action="DeleteWholeFolder">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow">
                                <i class="bi bi-trash3 me-2"></i>Delete Folder
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill border">Cancel, keep it</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>