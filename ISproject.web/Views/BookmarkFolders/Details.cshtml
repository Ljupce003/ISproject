@model ISproject.Domain.Models.BookmarkFolder

@{
    ViewData["Title"] = "Folder Properties";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="bg-primary p-5 text-white text-center">
                        <i class="bi bi-folder2 fs-1"></i>
                        <h2 class="fw-bold mt-2">@Model.Name</h2>
                        <p class="mb-0 opacity-75">Folder Properties</p>
                    </div>
                    <div class="p-4">
                        <div class="row mb-3">
                            <div class="col-4 fw-bold text-secondary">Owner ID:</div>
                            <div class="col-8"><code class="text-primary">@Model.User?.Id</code></div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-4 fw-bold text-secondary">Total Articles:</div>
                            <div class="col-8"><span class="badge bg-secondary">@Model.ArticleInFolders?.Count()</span></div>
                        </div>

                        <div class="d-flex justify-content-center gap-2 border-top pt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back</a>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm fw-bold">
                                <i class="bi bi-pencil"></i> Rename
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>