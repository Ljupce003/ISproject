@model IEnumerable<ISproject.Domain.Models.BookmarkFolder>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* <h1>Bookmark Folders</h1> *@

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold text-primary">📂 Bookmark Folders</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Create New Folder
    </a>
</div>

@* <p>
    <a asp-action="Create" class="btn btn-success">Create New Folder</a>
</p> *@


@foreach (var folder in Model)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title mb-1">@folder.Name</h5>
                    <small class="text-muted">
                        @(folder.ArticleInFolders?.Count() ?? 0) articles
                    </small>
                </div>
                <div class="d-flex gap-5">
					<div>
						<a asp-action="ExportToCSV" asp-route-id="@folder.Id" class="btn btn-primary btn-sm">Export</a>
					</div>
					<div class="btn-group">
						<a asp-action="Edit" asp-route-id="@folder.Id" class="btn btn-warning btn-sm">Edit</a>
						<a asp-action="Details" asp-route-id="@folder.Id" class="btn btn-info btn-sm">Details</a>
						<a asp-action="Delete" asp-route-id="@folder.Id" class="btn btn-danger btn-sm">Delete</a>
					</div>
                </div>
                
            </div>

            @* Articles inside this folder *@
            @if (folder.ArticleInFolders != null && folder.ArticleInFolders.Any())
            {
                <div class="mt-3">
                    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#articles-@folder.Id">
                        Show Articles
                    </button>

                    <div class="collapse mt-2" id="articles-@folder.Id">
                        <table class="table table-sm table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Description</th>
                                    <th>Author</th>
                                    <th>Url</th>
                                    <th style="width:160px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var articleInFolder in folder.ArticleInFolders)
                                {
                                    var article = articleInFolder.NewsArticle;
                                    if (article != null)
                                    {
                                        <tr>
                                            <td>@article.Title</td>
                                            <td>@(article.Description != null ? article.Description.Substring(0, Math.Min(article.Description.Length, 40)) + "..." : "")
                                            </td>
                                            <td>@article.Author</td>
                                            <td><a href="@article.Url" target="_blank">Link</a></td>
                                            <td>
                                                <div class="d-flex gap-1 ms-4">
                                                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="ArticleInFolders" asp-route-id="@articleInFolder.Id">Edit</a>
                                                    <a class="btn btn-info btn-sm" asp-action="Details" asp-controller="ArticleInFolders" asp-route-id="@articleInFolder.Id">Details</a>
                                                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-controller="ArticleInFolders" asp-route-id="@articleInFolder.Id">Delete</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
}

