@model IEnumerable<ISproject.Domain.Models.BookmarkFolder>

@{
    ViewData["Title"] = "My Collections";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold text-dark mb-0">📂 Bookmark Folders</h1>
            <p class="text-muted">Organize your research and export collections to CSV.</p>
        </div>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="bi bi-folder-plus me-2"></i> New Folder
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border-2 border-dashed rounded-4 bg-light">
            <i class="bi bi-folder2-open fs-1 text-secondary"></i>
            <h4 class="mt-3 text-secondary">No folders yet</h4>
            <p class="text-muted">Create your first folder to start organizing bookmarks.</p>
        </div>
    }

    @foreach (var folder in Model)
    {
        <div class="card border-0 shadow-lg rounded-4 mb-4 overflow-hidden">
            <div class="card-header bg-white border-0 py-3 px-4">
                <div class="row align-items-center">
                    <div class="col">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-folder-fill text-primary fs-3 me-3"></i>
                            <div>
                                <h5 class="fw-bold mb-0">@folder.Name</h5>
                                <span class="badge bg-primary-subtle text-primary rounded-pill">
                                    @(folder.ArticleInFolders?.Count() ?? 0) Articles
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-auto">
                        <div class="d-flex gap-2">
                            <a asp-action="ExportToCSV" asp-route-id="@folder.Id" class="btn btn-outline-success btn-sm rounded-pill px-3">
                                <i class="bi bi-file-earmark-excel me-1"></i> Export
                            </a>
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                                <a asp-action="Edit" asp-route-id="@folder.Id" class="btn btn-white btn-sm" title="Rename"><i class="bi bi-pencil text-warning"></i></a>
                                <a asp-action="Details" asp-route-id="@folder.Id" class="btn btn-white btn-sm" title="View"><i class="bi bi-eye text-info"></i></a>
                                <a asp-action="Delete" asp-route-id="@folder.Id" class="btn btn-white btn-sm" title="Delete"><i class="bi bi-trash text-danger"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body bg-light-subtle p-0 border-top">
                <div class="px-4 py-2 d-flex justify-content-between align-items-center">
                    <button class="btn btn-link text-decoration-none text-secondary fw-bold p-0 small"
                            type="button" data-bs-toggle="collapse" data-bs-target="#articles-@folder.Id">
                        <i class="bi bi-chevron-down me-1"></i> View Articles in Folder
                    </button>
                </div>

                <div class="collapse" id="articles-@folder.Id">
                    <div class="table-responsive">
                        @if (folder.ArticleInFolders != null && folder.ArticleInFolders.Any())
                        {
                            <table class="table table-hover align-middle mb-0 bg-white shadow-sm">
                                <thead class="table-light">
                                    <tr class="small text-uppercase">
                                        <th class="ps-4">Title</th>
                                        <th>Description</th>
                                        <th>Author</th>
                                        <th>Link</th>
                                        <th class="text-end pe-4">Management</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var articleInFolder in folder.ArticleInFolders)
                                    {
                                        var article = articleInFolder.NewsArticle;
                                        if (article != null)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-semibold text-dark">@article.Title</td>
                                                <td class="text-muted small">
                                                    @(article.Description != null ? (article.Description.Length > 60 ? article.Description.Substring(0, 60) + "..." : article.Description) : "N/A")
                                                </td>
                                                <td><span class="badge bg-light text-secondary border">@article.Author</span></td>
                                                <td>
                                                    <a href="@article.Url" target="_blank" class="btn btn-sm btn-link"><i class="bi bi-box-arrow-up-right"></i></a>
                                                </td>
                                                <td class="text-end pe-4">
                                                    <div class="btn-group btn-group-sm rounded-pill border overflow-hidden">
                                                        <a class="btn btn-white" asp-action="Edit" asp-controller="ArticleInFolders" asp-route-id="@articleInFolder.Id"><i class="bi bi-pencil text-warning"></i></a>
                                                        <a class="btn btn-white" asp-action="Details" asp-controller="ArticleInFolders" asp-route-id="@articleInFolder.Id"><i class="bi bi-info-circle text-info"></i></a>
                                                        <a class="btn btn-white" asp-action="Delete" asp-controller="ArticleInFolders" asp-route-id="@articleInFolder.Id"><i class="bi bi-x-circle text-danger"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted italic">
                                <p class="mb-0"><i class="bi bi-info-circle me-1"></i> This folder is currently empty.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .bg-light-subtle {
        background-color: #fcfcfd;
    }

    .btn-white {
        background: white;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    .card {
        transition: transform 0.2s ease, shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-2px);
        }
</style>