@model ISproject.Domain.Models.NewsSource

@{
    ViewData["Title"] = "Remove Source";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger py-4 text-center border-0 text-white">
                    <i class="bi bi-exclamation-triangle fs-1 mb-2"></i>
                    <h3 class="fw-bold mb-0">Confirm Removal</h3>
                </div>

                <div class="card-body p-5 text-center">
                    <p class="text-muted fs-5 mb-4">
                        You are about to delete <br />
                        <span class="text-dark fw-bold fs-3">"@Model.Name"</span>
                    </p>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <span class="badge bg-light text-secondary border px-3 py-2">Code: @Model.Code</span>
                        <span class="badge bg-light text-secondary border px-3 py-2">Region: @Model.Country?.Name</span>
                    </div>

                    <div class="alert alert-warning border-0 small mb-4">
                        <i class="bi bi-info-circle me-2"></i>
                        Warning: Deleting this source may affect articles linked to it.
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow">
                                <i class="bi bi-trash3 me-2"></i> Yes, Delete Source
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill border">
                                No, Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>