<button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#sourceForm">
    Fetch Sources
</button>

<div class="collapse mt-3" id="sourceForm">
    <div class="card card-body">
        <form method="get" asp-controller="Api" asp-action="GetNewsSources">
            <input type="text" name="sourceKeyword" class="form-control mb-2" placeholder="Enter keyword..." />
            <button type="submit" class="btn btn-success">Fetch</button>
        </form>
    </div>
</div>



<table class="table mt-1 table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Code)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Url)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Country)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Language)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Code)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                <a href="@item.Url">Link</a>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.Code)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Country.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Language.Name)
            </td>
            <td>
                 <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                 <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id">Details</a>
                 <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>


