@model IEnumerable<ISproject.Domain.Models.NewsSource>

@{
    ViewData["Title"] = "News Sources";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .source-table thead {
        background-color: #f8f9fa;
        border-top: 2px solid #0d6efd;
    }

    .btn-action {
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: transform 0.2s;
        border: none;
        color: white !important;
    }

        .btn-action:hover {
            transform: scale(1.1);
        }

    .fetch-card {
        border-radius: 15px;
        border: none;
        background-color: #f0f7ff;
    }
</style>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold text-primary mb-0">📡 News Sources</h1>
            <p class="text-muted">Manage and discover verified news outlets</p>
        </div>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="d-flex gap-2">
                <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-lg"></i> Create New
                </a>
                <button class="btn btn-outline-primary rounded-pill px-4 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#sourceForm">
                    <i class="bi bi-cloud-download"></i> Fetch Sources
                </button>
            </div>
        }
    </div>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="collapse mb-4" id="sourceForm">
            <div class="card fetch-card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-search me-2"></i>API Import</h5>
                    <form method="get" asp-controller="Api" asp-action="GetNewsSources" class="row g-2">
                        <div class="col-md-9">
                            <input type="text" name="sourceKeyword" class="form-control border-0 shadow-sm py-2" placeholder="Search for sources by keyword (e.g. 'Technology', 'BBC')..." />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100 py-2 rounded-3 shadow-sm">
                                <i class="bi bi-arrow-repeat me-1"></i> Fetch from API
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 source-table">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Code)</th>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>Category</th>
                        <th>Region</th>
                        <th>Language</th>
                        <th class="text-center">Website</th>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <th class="text-end pe-4">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4"><code class="fw-bold text-primary">@item.Code</code></td>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2">
                                    @item.Category?.Code
                                </span>
                            </td>
                            <td>
                                <small class="fw-bold"><i class="bi bi-geo-alt text-danger"></i> @item.Country?.Name</small>
                            </td>
                            <td>
                                <small class="text-muted">@item.Language?.Name</small>
                            </td>
                            <td class="text-center">
                                <a href="@item.Url" target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </td>
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a class="btn btn-warning btn-action shadow-sm" asp-action="Edit" asp-route-id="@item.Id" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a class="btn btn-info btn-action shadow-sm" asp-action="Details" asp-route-id="@item.Id" title="Details">
                                            <i class="bi bi-info-circle-fill"></i>
                                        </a>
                                        <a class="btn btn-danger btn-action shadow-sm" asp-action="Delete" asp-route-id="@item.Id" title="Delete">
                                            <i class="bi bi-trash3-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 text-end text-muted small">
        Showing @Model.Count() news sources
    </div>
</div>