@model IEnumerable<ISproject.Domain.Models.NewsSource>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index - News Sources</h1>

<p>
    <a asp-action="Create" class="btn-success btn">Create New</a>
</p>

