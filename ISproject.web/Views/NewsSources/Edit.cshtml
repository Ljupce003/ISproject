@model ISproject.Domain.Models.NewsSource

@{
    ViewData["Title"] = "Edit Source";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">News Sources</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit @Model.Name</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-warning py-4 px-4 border-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-white rounded-circle p-2 me-3 shadow-sm">
                            <i class="bi bi-broadcast text-warning fs-4"></i>
                        </div>
                        <h3 class="mb-0 fw-bold text-dark">Edit News Source</h3>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-md-4">
                                <label asp-for="Code" class="form-label fw-bold text-secondary">Source Code</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-tag"></i></span>
                                    <input asp-for="Code" class="form-control border-start-0 py-2 fw-bold text-primary" placeholder="bbc-news" />
                                </div>
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>

                            <div class="col-md-8">
                                <label asp-for="Name" class="form-label fw-bold text-secondary">Display Name</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-building"></i></span>
                                    <input asp-for="Name" class="form-control border-start-0 py-2" placeholder="BBC News" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Url" class="form-label fw-bold text-secondary">Website URL</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-globe"></i></span>
                                    <input asp-for="Url" class="form-control border-start-0 py-2" placeholder="https://www.bbc.com" />
                                </div>
                                <span asp-validation-for="Url" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="CategoryId" class="form-label fw-bold text-secondary">Category</label>
                                <select asp-for="CategoryId" class="form-select shadow-sm" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Category --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="CountryId" class="form-label fw-bold text-secondary">Country</label>
                                <select asp-for="CountryId" class="form-select shadow-sm" asp-items="ViewBag.CountryId">
                                    <option value="">-- Country --</option>
                                </select>
                                <span asp-validation-for="CountryId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="LanguageId" class="form-label fw-bold text-secondary">Language</label>
                                <select asp-for="LanguageId" class="form-select shadow-sm" asp-items="ViewBag.LanguageId">
                                    <option value="">-- Language --</option>
                                </select>
                                <span asp-validation-for="LanguageId" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-4 pt-4 border-top">
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-warning px-5 rounded-pill text-white fw-bold shadow-sm">
                                        <i class="bi bi-save me-1"></i> Update Source
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary px-5 rounded-pill shadow-sm">
                                        Cancel
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}